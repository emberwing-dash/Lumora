  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NekoInteractionController
  nekoDialogueTyper: {fileID: 1805354013}
  playerDialogueTyper: {fileID: 0}
  dialogueSet:
  - speaker: Player
    lines:
    - Hi, what happened
    - Why are u in such a rush?
  - speaker: Neko
    lines:
    - A horde of goblins suddenly jumped me
    - "(\u2565\uFE4F\u2565)"
  - speaker: Player
    lines:
    - Oh no, are you alright?
  - speaker: Neko
    lines:
    - Yes, i am alright now
    - I was collecting fruits in the forest
    - But the goblins saw me and chased me
  - speaker: Player
    lines:
    - I see. Any way I can help?
  - speaker: Neko
    lines:
    - Yes, you can
    - Can you help me by defeating those goblins?
  - speaker: Player
    lines:
    - Yes sure
    - I would be happy to help out a lady in need
    - "(\u02F5 \u2022\u0300 \u1D17 - \u02F5 ) \u2727"
  - speaker: Neko
    lines:
    - Why aren't you confident?
    - There's a sword over there which you can use
    - "\uA242(\u02F5\u02C3 \u15DC \u02C2\u02F5)"
    - Right over there on the stone pedestal
